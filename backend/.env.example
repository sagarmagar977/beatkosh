DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost,192.168.1.93
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
DJANGO_SECURE_SSL_REDIRECT=False
DJANGO_DB_SSL_REQUIRE=True
DB_CONN_MAX_AGE=0
DJANGO_TIME_ZONE=Asia/Kathmandu

# Uncomment for PostgreSQL
# POSTGRES_DB=beatkosh
# POSTGRES_USER=postgres
# POSTGRES_PASSWORD=postgres
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5432
# Or use a full DATABASE_URL (recommended for Render/Supabase)
# DATABASE_URL=postgresql://user:pass@host:port/dbname

# Optional local override to force SQLite even when DATABASE_URL exists
# FORCE_SQLITE=False

# ImageKit media storage
IMAGEKIT_ENABLED=False
IMAGEKIT_PUBLIC_KEY=
IMAGEKIT_PRIVATE_KEY=
IMAGEKIT_URL_ENDPOINT=
IMAGEKIT_MEDIA_ROOT=BeatKosh

# Production example values for Render
# DJANGO_DEBUG=False
# DJANGO_ALLOWED_HOSTS=your-backend.onrender.com
# DJANGO_CSRF_TRUSTED_ORIGINS=https://your-frontend-domain.com,https://your-backend.onrender.com
# DJANGO_SECURE_SSL_REDIRECT=True
# DB_CONN_MAX_AGE=0

# Local webhook secrets (optional but recommended for local security testing)
PAYMENT_WEBHOOK_SECRET_ESEWA=local-esewa-secret
PAYMENT_WEBHOOK_SECRET_KHALTI=local-khalti-secret
PAYMENT_WEBHOOK_SECRET_CONNECTIPS=local-connectips-secret
PAYMENT_WEBHOOK_SECRET_PAYU=local-payu-secret
